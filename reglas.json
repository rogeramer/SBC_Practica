  "guides": {
    "stardew valley": ["Planta semillas y riégalas.", "No gastes toda la energía de golpe.", "Habla con el pueblo."],
    "journey": ["Juega sin prisas.", "La experiencia es más importante que ganar.", "Ideal para relajarse."],
    "valorant": ["Empieza con agentes sencillos.", "Aprende el mapa.", "Comunícate con tu equipo."],
    "rocket league": ["Aprende a rotar.", "No persigas la pelota a lo loco.", "Practica disparos básicos."],
    "life is strange": ["Tómate tiempo para explorar.", "Tus decisiones importan.", "Céntrate en la historia."],
    "the witcher 3": ["Haz misiones secundarias.", "Usa señales y pociones.", "Consulta el bestiario."],
    "minecraft": ["Consigue madera y refugio rápido.", "Haz una cama antes de la noche.", "Explora con calma."],
    "overcooked 2": ["Organiza las tareas.", "La coordinación es vital.", "No corras sin sentido."],
    "into the breach": ["Minimiza daño.", "Mover enemigos es muy útil.", "Piensa como si fuera ajedrez."],
    "slay the spire": ["No cojas cartas al azar.", "Quitar cartas malas es bueno.", "Busca sinergias."],
    "hades": ["Morir es parte del juego.", "Prueba varias armas.", "Mejora en el espejo de la noche."],
    "dark souls": ["Ve despacio y observa.", "Gestiona la estamina.", "Ten mucha paciencia."],
    "phasmophobia": ["Empieza en dificultad baja.", "Usa bien los objetos.", "No hables solo para molestar al fantasma."],
    "resident evil 2": ["Ahorra munición.", "No mates a todos los zombis.", "Revisa bien el mapa."],
    "dead cells": ["No te encariñes con tus armas, prueba todo.", "Aprende a esquivar rodando.", "Invierte células de forma inteligente."],
    "apex legends": ["Juega en equipo y no te separes.", "Aprende a usar el sistema de 'pings' (marcar).", "La movilidad es la clave para ganar."],
    "left 4 dead 2": ["Manteneos juntos siempre.", "Comparte las curas.", "Escucha los sonidos de los infectados especiales."],
    "it takes two": ["La comunicación es el 100% del juego.", "No os enfadéis si falláis.", "Disfrutad de los minijuegos secundarios."],
    "valheim": ["Tala árboles pero cuidado de que no te caigan encima.", "Come tres tipos de comida diferentes.", "Construye cerca del agua al principio."],
    "civilization vi": ["No descuides tu ejército aunque busques paz.", "Planifica los distritos con antelación.", "Juega el tutorial, hay mucha información."],
    "five nights at freddys": ["Ahorra batería, no mires las cámaras todo el rato.", "Escucha los pasos.", "Cierra las puertas solo si es estrictamente necesario."],
    "brawl stars": ["Céntrate en los objetivos del modo de juego, no solo en matar.", "Usa los muros para cubrirte.", "Juega en equipo y no vayas solo a por los rivales."],
    "call of duty": ["Conoce el mapa y los puntos de reaparición.", "Ajusta la sensibilidad de tu cámara para apuntar mejor.", "Comunícate siempre si juegas en equipo."],
    "solitario": ["Revela las cartas ocultas siempre que puedas.", "No vacíes un hueco si no tienes un Rey para poner.", "Piensa dos movimientos por delante."],
    "clash royale": ["No gastes todo tu elixir de golpe.", "Aprende a defender con tropas baratas.", "Conoce el daño exacto que hacen tus hechizos a las torres."],
    "ajedrez": ["Controla el centro del tablero desde el principio.", "Desarrolla tus piezas menores (caballos y alfiles) rápido.", "Protege a tu rey enrocando pronto."],
    "clash of clans": ["No mejores tu ayuntamiento hasta tener todo lo demás al máximo.", "Guarda tus gemas para comprar constructores.", "Únete a un clan activo pronto para pedir tropas."],
    "fall guys": ["No siempre ir el primero es lo mejor, observa los obstáculos.", "Aprende a usar el salto en plancha (dive) para llegar más lejos.", "Ten mucha paciencia en los niveles de supervivencia."],
    "mario kart": ["Guarda los objetos defensivos (conchas verdes/plátanos) para protegerte la espalda.", "Aprende a derrapar en las curvas para conseguir miniturbos.", "Coge 10 monedas lo más rápido que puedas para correr más."]
